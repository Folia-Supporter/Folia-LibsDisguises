+
+        Disguise finalDisguise = disguise;
+
+        if (disguise.getEntity() != null ||
+            DisguiseUtilities.getFutureDisguises().values().stream().anyMatch(v -> v.contains(finalDisguise))) {
+            disguise = disguise.clone();
