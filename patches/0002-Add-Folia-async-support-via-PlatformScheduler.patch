-        if (getPacketEntityType() == null) {
-            throw new IllegalStateException(
-                "Unable to find the packetevents entity type for " + name() + " with EntityType enum of " + getEntityType().name() +
-                    " and name of " + getEntityType().getName());
-        }
-    }
