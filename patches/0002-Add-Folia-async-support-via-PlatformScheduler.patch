+    @Override
+    public Object getEntityTracker(Entity target) throws Exception {
+        net.minecraft.world.entity.Entity nmsEntity = (net.minecraft.world.entity.Entity) getNmsEntity(target);
+
+        // Folia way: try to get trackedEntity field from Entity directly
+        try {
+            java.lang.reflect.Field trackedEntityField = net.minecraft.world.entity.Entity.class.getDeclaredField("trackedEntity");
+            trackedEntityField.setAccessible(true);
+            Object tracker = trackedEntityField.get(nmsEntity);
+            if (tracker != null) {
+                return tracker;
+            }
+        } catch (NoSuchFieldException ignored) {
+        }
+
+        // Traditional way: get from ChunkMap's entityMap
+        ServerLevel world = getWorldServer(target.getWorld());
+        ChunkMap chunkMap = world.getChunkSource().chunkMap;
+
+        try {
+            java.lang.reflect.Field entityMapField = ChunkMap.class.getDeclaredField("entityMap");
+            entityMapField.setAccessible(true);
+            it.unimi.dsi.fastutil.ints.Int2ObjectMap<ChunkMap.TrackedEntity> entityMap =
+                (it.unimi.dsi.fastutil.ints.Int2ObjectMap<ChunkMap.TrackedEntity>) entityMapField.get(chunkMap);
+            return entityMap.get(target.getEntityId());
+        } catch (NoSuchFieldException e) {
+            throw new RuntimeException("Unable to find entityMap field in ChunkMap", e);
+        }
+    }
