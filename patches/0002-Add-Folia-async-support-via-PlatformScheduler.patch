+        return getData(MetaIndex.OCELOT_TRUST);
+    }
+
+    @NmsAddedIn(NmsVersion.v1_14)
+    public void setTrusting(boolean trusting) {
+        sendData(MetaIndex.OCELOT_TRUST, trusting);
