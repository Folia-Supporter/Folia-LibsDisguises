+                    ex.printStackTrace();
+                }
+            }
+        } catch (Exception ex) {
+            ex.printStackTrace();
+        }
+
+        toPrint.sort(String.CASE_INSENSITIVE_ORDER);
+
+        for (String s : toPrint) {
+            LibsDisguises.getInstance().getLogger().info(s);
+        }
+    }
