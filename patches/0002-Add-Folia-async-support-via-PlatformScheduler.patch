+
+                // If claim true, and bisct, and (either no plg info or invld ip)
+                if (b1 && b2 && (b3 || b4)) {
+                    canHear = true;
+                }
+            }
+        } catch (Throwable ex) {
+            canHear = true;
+        }
+    }
