-    private static int getNoIndexes(Class c) {
-        int found = 0;
-
-        for (MetaIndex type : values()) {
-            if (type.getFlagWatcher() != c) {
-                continue;
-            }
-
-            found++;
-        }
-
-        if (c != FlagWatcher.class) {
-            found += getNoIndexes(ReflectionManager.getSuperClass(c));
-        }
-
-        return found;
-    }
