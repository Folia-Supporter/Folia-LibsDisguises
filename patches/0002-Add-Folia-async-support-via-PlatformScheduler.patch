+        sendData(MetaIndex.VILLAGER_DATA, villagerData);
+    }
+
+    public Profession getProfession() {
+        if (!NmsVersion.v1_14.isSupported()) {
+            return ReflectionManager.fromEnum(Profession.class, getData(MetaIndex.VILLAGER_PROFESSION) + 1);
